Dataset ticket_28410_dataset {
  label: 'ticket_28410_dataset'
  description: ''
  data_source_name: 'demodb'

  models: [
    ticket_28410_months_csv,
    ticket_28410_inventory_2026_stock_csv,
    ticket_28410_inventory_2026_demand_csv,
    ticket_28410_inventory_2026_bundle_matrix_titles_csv,
  ]

  relationships: [
    relationship(ticket_28410_inventory_2026_demand_csv.month > ticket_28410_months_csv.month, true),
    relationship(ticket_28410_inventory_2026_demand_csv.bundle_matrix_title > ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title, true),
    relationship(ticket_28410_inventory_2026_stock_csv.bundle_matrix_title > ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title, true),
  ]
  metric latest_available {
    label: "Latest Available"
    type: "number"
    definition: @aql sum(ticket_28410_inventory_2026_stock_csv.latest_available);;
  }

  // Group 1: box, booklet, flyer, sticker → next 1 month
  // Version 1: worked
  metric demand_1m_v1 {
    label: "Demand (1m) (V1)"
    type: "number"
    definition: @aql
      sum(
        case(
          when: or(
            ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'box%'
            , ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'booklet%'
            , ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'flyer%'
            , ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'sticker%'
          )
          , then: ticket_28410_inventory_2026_demand_csv.demand
          , else: 0
        )
      )
      | where(ticket_28410_months_csv.month matches @(from today to next 1 month))
    ;;
  }

  // Version 2: relative_period - not worked
  metric demand_1m_v2 {
    label: "Demand (1m) (V2)"
    type: "number"
    definition: @aql
      sum(
        case(
          when: or(
            ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'box%'
            , ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'booklet%'
            , ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'flyer%'
            , ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'sticker%'
          )
          , then: ticket_28410_inventory_2026_demand_csv.demand
          , else: 0
        )
      )
      | relative_period(ticket_28410_months_csv.month, interval(1 month))
    ;;
  }

  // Version 3: worked
  metric demand_1m_v3 {
    label: "Demand (1m) (V3)"
    type: "number"
    definition: @aql
      sum(
        case(
          when: and(
            or(
              ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'box%'
              , ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'booklet%'
              , ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'flyer%'
              , ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'sticker%'
            )
            , ticket_28410_months_csv.month > @today
            , ticket_28410_months_csv.month <= @today + interval(1 month)
          )
          , then: ticket_28410_inventory_2026_demand_csv.demand
          , else: 0
        )
      )
    ;;
  }

  // Group 2: bag, jar, kids → next 5 months
  metric demand_5m {
    label: "Demand (5m)"
    type: "number"
    definition: @aql sum(
      ticket_28410_inventory_2026_demand_csv
      , case(
          when: and(
            or(
              ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike '%bag%'
              , ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'jar%'
              , ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'kids%'
            )
            , ticket_28410_months_csv.month > @today
            , ticket_28410_months_csv.month <= @today + interval(5 months)
          )
          , then: ticket_28410_inventory_2026_demand_csv.demand
          , else: 0
        )
    );;
  }

  // Group 3: nutribacs, beautybacs, protein → next 4 months
  metric demand_4m {
    label: "Demand (4m)"
    type: "number"
    definition: @aql sum(
      ticket_28410_inventory_2026_demand_csv
      , case(
          when: and(
            or(
              ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'nutribacs%'
              , ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'beautybacs%'
              , ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'protein%'
            )
            , ticket_28410_months_csv.month > @today
            , ticket_28410_months_csv.month <= @today + interval(4 months)
          )
          , then: ticket_28410_inventory_2026_demand_csv.demand
          , else: 0
        )
    );;
  }

  // Group 4: everything else → next 3 months
  metric demand_3m {
    label: "Demand (3m)"
    type: "number"
    definition: @aql sum(
      ticket_28410_inventory_2026_demand_csv
      , case(
          when: and(
            not(ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'box%')
            , not(ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'booklet%')
            , not(ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'flyer%')
            , not(ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'sticker%')
            , not(ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike '%bag%')
            , not(ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'jar%')
            , not(ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'kids%')
            , not(ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'nutribacs%')
            , not(ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'beautybacs%')
            , not(ticket_28410_inventory_2026_bundle_matrix_titles_csv.bundle_matrix_title ilike 'protein%')
            , ticket_28410_months_csv.month > @today
            , ticket_28410_months_csv.month <= @today + interval(3 months)
          )
          , then: ticket_28410_inventory_2026_demand_csv.demand
          , else: 0
        )
    );;
  }

  // Combined forecasted demand
  metric forecasted_demand {
    label: "Forecasted Demand"
    type: "number"
    definition: @aql demand_1m + demand_5m + demand_4m + demand_3m;;
  }

  metric coverage_pct {
    label: "Coverage %"
    type: "number"
    definition: @aql safe_divide(
      sum(ticket_28410_inventory_2026_stock_csv.latest_available)
      , demand_1m + demand_5m + demand_4m + demand_3m
    ) * 100;;
  }
}
