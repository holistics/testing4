
const dark_background_color = 'green'
const dark_surface_color = 'green'
const dark_border_color = 'purple'
const dark_text_color = 'white'
const dark_muted_color = 'gray'
const dark_placeholder_color = 'red'
const dark_active_background_color = 'purple'
const dark_active_text_color = 'black'

    //  ${dark_background_color}         main panel / canvas bg
    //  ${dark_surface_color}             NEW — input/dropdown bg  (slightly lighter than main bg)
    //  ${dark_border_color}              NEW — dividers & borders
    //  ${dark_text_color}                primary text
    //  ${dark_muted_color}               NEW — secondary/empty-state text
    //  ${dark_placeholder_color}         input placeholders
    //  ${dark_active_background_color}   hover / active states

const squad_dark_pro_max = squad_dark.extend({
  custom_css: @css 
      /* =================================================================
     (A) ELEMENTS INSIDE .h-dac-theme
     ================================================================= */
 
  /* ---------- Top "Insights" title row (previously unstyled) ---------- */
  /* Real class: .dac-metadata  (NOT h-embed-header / h-dashboard-header) */
  .dac-metadata {
    background: ${dark_background_color} !important;
    color: ${dark_text_color} !important;
    border-bottom-color: ${dark_border_color} !important;
  }
  .dac-metadata svg,
  .dac-metadata .h-icon {
    color: ${dark_text_color} !important;
    fill: currentColor !important;
  }
 
 
  /* ---------- Toolbar row: tabs + Controls button + timezone ----------
     Your existing rule listed .h-dac-toolbar but only styled its
     *descendants* (because of the nested :not(.dac-canvas) pattern).
     The white bg is ON the toolbar itself — we need to hit it directly. */
  .h-dac-toolbar,
  .h-dac-toolbar-left,
  .h-dac-toolbar-right,
  .h-tabs-switch {
    background: ${dark_background_color} !important;
    border-bottom-color: ${dark_border_color} !important;
    border-color: ${dark_border_color} !important;
  }
 
 
  /* ---------- Tabs: Overview / Games / Players ----------
     Real class: .h-tab-page
     Active tab has utility classes: .active .border-b-blue-600 .bg-gray-100
     Hover pseudo: .hover\:bg-gray-100 */
  .h-tab-page {
    color: ${dark_text_color} !important;
    background: transparent !important;
  }
  .h-tab-page:hover {
    background: ${dark_active_background_color} !important;
    color: ${dark_text_color} !important;
  }
  /* Active tab — override the .bg-gray-100 utility directly */
  .h-tab-page.active,
  .h-tab-page.active.bg-gray-100 {
    background: ${dark_active_background_color} !important;
    color: ${dark_text_color} !important;
    /* keep the bottom accent visible on dark; use your brand color if you like */
    border-bottom-color: ${dark_text_color} !important;
  }
 
 
  /* ---------- Toolbar buttons: Controls toggle & timezone ----------
     Both use the .hui-btn-light variant — that's why they stayed light. */
  .h-dac-toolbar .hui-btn,
  .h-dac-toolbar .hui-btn-light {
    background: transparent !important;
    color: ${dark_text_color} !important;
    border-color: ${dark_border_color} !important;
  }
  .h-dac-toolbar .hui-btn:hover,
  .h-dac-toolbar .hui-btn-light:hover {
    background: ${dark_active_background_color} !important;
    color: ${dark_text_color} !important;
  }
 
 
  /* ---------- Zoom trigger (already working from your last round) ---------- */
  [data-ci="ci-zoom-dropdown"] {
    background: ${dark_background_color} !important;
    color: ${dark_text_color} !important;
    border-color: ${dark_border_color} !important;
  }
  [data-ci="ci-zoom-dropdown"]:hover {
    border-color: ${dark_active_background_color} !important;
  }
 
 
  /* =================================================================
     (B) POPOVERS — PORTALED OUTSIDE .h-dac-theme
     These open when you click the zoom trigger, the "equal" operator,
     the value input dropdown, the timezone button, etc.
     MUST be written at the top level (no prefix).
     ================================================================= */
  .hui-popper-floating-inner,
  [data-hui-section="popper-floating"],
  .hui-dropdown-menu,
  .hui-select-menu {
    background: ${dark_background_color} !important;
    color: ${dark_text_color} !important;
    border-color: ${dark_border_color} !important;
    box-shadow: none !important;
  }
 
  /* Items inside popovers: menu items, options, zoom actions */
  .hui-popper-floating-inner .hui-dropdown-item,
  .hui-popper-floating-inner [role="menuitem"],
  .hui-popper-floating-inner [role="option"],
  [data-hui-section="popper-floating"] .hui-dropdown-item,
  [data-hui-section="popper-floating"] [role="menuitem"],
  [data-hui-section="popper-floating"] [role="option"] {
    color: ${dark_text_color} !important;
    background: transparent !important;
  }
  .hui-popper-floating-inner .hui-dropdown-item:hover,
  .hui-popper-floating-inner [role="menuitem"]:hover,
  .hui-popper-floating-inner [role="option"]:hover,
  .hui-popper-floating-inner [role="menuitem"][data-highlighted],
  .hui-popper-floating-inner [role="option"][aria-selected="true"],
  [data-hui-section="popper-floating"] .hui-dropdown-item:hover,
  [data-hui-section="popper-floating"] [role="menuitem"]:hover,
  [data-hui-section="popper-floating"] [role="option"]:hover {
    background: ${dark_active_background_color} !important;
    color: ${dark_text_color} !important;
  }
 
  /* Inputs inside popovers (zoom % input, operator search, value search) */
  .hui-popper-floating-inner input,
  [data-hui-section="popper-floating"] input {
    background: ${dark_background_color} !important;
    color: ${dark_text_color} !important;
    border-color: ${dark_border_color} !important;
  }
  .hui-popper-floating-inner input::placeholder,
  [data-hui-section="popper-floating"] input::placeholder {
    color: ${dark_placeholder_color} !important;
  }
 
  /* Tailwind .bg-white inside popovers (zoom menu wrapper uses it) */
  .hui-popper-floating-inner .bg-white,
  [data-hui-section="popper-floating"] .bg-white {
    background: ${dark_background_color} !important;
  }
 
 
  /* =================================================================
     OPTIONAL: the "nuclear" .bg-white override you asked about.
     Scoped to AND excluded from .dac-canvas and its
     descendants, so in-canvas widgets keep their per-block theming.
     Uncomment if you prefer a broader catch-all over specific rules.
     ================================================================= */
  /*
  .bg-white:not(.dac-canvas):not(.dac-canvas *) {
    background: ${dark_background_color} !important;
  }
  */
  ;;
})

Dashboard test_zoom {
  title: 'Insights'
  description: ''

  view: TabLayout {
    label: 'View 1'
    tab tab1: CanvasLayout {
      default_zoom: 'fit_to_width'
      label: 'Overview'
      width: 1700
      height: 2840
      grid_size: 20
      auto_expand_vertically: true

      mobile {
        mode: 'auto'
      }
      block f_airbnb_listings_id {
        position: pos(710, 1980, 300, 80)
      }
      block f_airbnb_listings_id_vuz1 {
        position: pos(540, 600, 300, 80)
      }
    }
    tab tab2: CanvasLayout {
      default_zoom: 'fit_to_width'
      label: 'Games'
      width: 1700
      height: 540
      grid_size: 20
      auto_expand_vertically: true
      mobile {
        mode: 'auto'
      }
    }
    tab tab_l4op: CanvasLayout {
      default_zoom: 'fit_to_width'
      label: 'Players'
      width: 1700
      height: 1560
      grid_size: 20
      auto_expand_vertically: true
      mobile {
        mode: 'auto'
      }
    }
  }
  settings {
    timezone: 'Etc/UTC'
    allow_timezone_change: true
    cache_duration: 1440
  }
  theme: squad_dark_pro_max
  block f_airbnb_listings_id: FilterBlock {
    label: 'Airbnb Listings Id'
    type: 'field'
    source: FieldFilterSource {
      dataset: airbnb_data
      field: r(ecommerce_demo_pointmap_airbnb.id)
    }
    default {
      operator: 'is'
      value: '$H_NIL$'
    }
  }
  block f_airbnb_listings_id_vuz1: FilterBlock {
    label: 'Airbnb Listings Id'
    type: 'field'
    source: FieldFilterSource {
      dataset: airbnb_data
      field: r(ecommerce_demo_pointmap_airbnb.id)
    }
    default {
      operator: 'is'
      value: '$H_NIL$'
    }
  }
  interactions: [
    FilterInteraction {
      from: 'f_airbnb_listings_id'
      to: [
        CustomMapping {
          block: 'f_airbnb_listings_id_vuz1'
          disabled: true
        }
      ]
    },
    FilterInteraction {
      from: 'f_airbnb_listings_id_vuz1'
      to: [
        CustomMapping {
          block: 'f_airbnb_listings_id'
          disabled: true
        }
      ]
    }
  ]
}