
const dark_background_color = 'green'
const dark_surface_color = 'green'
const dark_border_color = 'purple'
const dark_text_color = 'white'
const dark_muted_color = 'gray'
const dark_placeholder_color = 'red'
const dark_active_background_color = 'purple'
const dark_active_text_color = 'black'

//  ${dark_background_color}         main panel / canvas bg
//  ${dark_surface_color}             NEW — input/dropdown bg  (slightly lighter than main bg)
//  ${dark_border_color}              NEW — dividers & borders
//  ${dark_text_color}                primary text
//  ${dark_muted_color}               NEW — secondary/empty-state text
//  ${dark_placeholder_color}         input placeholders
//  ${dark_active_background_color}   hover / active states

const squad_dark_pro_max = squad_dark.extend(
  {
    custom_css: @css 
/* ============================================================
   DARK MODE — consolidated, drop-in replacement
   Verified against the exported DOM + CSS bundles.
   Scopes:
     (A) Inside .h-dac-theme
     (B) Portaled popovers — top-level, NO prefix
   ============================================================ */

custom_css: @css

  /* =================================================================
     (A) INSIDE .h-dac-theme
     ================================================================= */

  /* ---- Top header rows ---------------------------------------- */
  .dac-metadata,
  .h-dac-toolbar,
  .h-dac-toolbar-left,
  .h-dac-toolbar-right,
  .h-tabs-switch {
    background: ${dark_background_color} !important;
    color: ${dark_text_color} !important;
    border-color: ${dark_border_color} !important;
  }

  /* Tabs: Overview / Games / Players */
  .h-tab-page {
    color: ${dark_text_color} !important;
    background: transparent !important;
  }
  .h-tab-page:hover,
  .h-tab-page.active,
  .h-tab-page.active.bg-gray-100 {
    background: ${dark_active_background_color} !important;
    color: ${dark_text_color} !important;
  }

  /* Toolbar buttons: Controls toggle + timezone (both use .hui-btn-light) */
  .h-dac-toolbar .hui-btn,
  .h-dac-toolbar .hui-btn-light {
    background: transparent !important;
    color: ${dark_text_color} !important;
    border-color: ${dark_border_color} !important;
  }
  .h-dac-toolbar .hui-btn:hover,
  .h-dac-toolbar .hui-btn-light:hover {
    background: ${dark_active_background_color} !important;
  }

  /* Icons in header/toolbar */
  .dac-metadata svg,
  .h-dac-toolbar svg,
  .dac-metadata .h-icon,
  .h-dac-toolbar .h-icon {
    color: ${dark_text_color} !important;
    fill: currentColor !important;
  }


  /* ---- Right Controls panel ----------------------------------- */
  /* The sidebar with "Controls" title, "In this tab", "From other tabs" */
  [data-ci="ci-controls-panel-content"],
  [data-ci*="controls-panel"] {
    background: ${dark_background_color} !important;
    color: ${dark_text_color} !important;
    border-color: ${dark_border_color} !important;
  }
  [data-ci*="controls-panel"] * {
    border-color: ${dark_border_color};
  }
  /* Inputs + operator select inside the panel */
  [data-ci*="controls-panel"] input,
  [data-ci*="controls-panel"] .operator-select,
  [data-ci*="controls-panel"] .hui-select,
  [data-ci*="controls-panel"] .hui-select-trigger,
  [data-ci*="controls-panel"] .filter-select,
  [data-ci*="controls-panel"] .filter-select-control {
    background: ${dark_background_color} !important;
    color: ${dark_text_color} !important;
    border-color: ${dark_border_color} !important;
  }
  [data-ci*="controls-panel"] input::placeholder {
    color: ${dark_placeholder_color} !important;
  }
  /* Icon buttons in the panel header: Reset, visibility, close */
  [data-ci*="controls-panel"] .hui-btn,
  [data-ci*="controls-panel"] button {
    color: ${dark_text_color} !important;
    background: transparent !important;
  }
  [data-ci*="controls-panel"] .hui-btn:hover,
  [data-ci*="controls-panel"] button:hover {
    background: ${dark_active_background_color} !important;
  }


  /* ---- Zoom trigger (bottom-right "46% ▼") -------------------- */
  [data-ci="ci-zoom-dropdown"] {
    background: ${dark_background_color} !important;
    color: ${dark_text_color} !important;
    border-color: ${dark_border_color} !important;
  }
  [data-ci="ci-zoom-dropdown"]:hover {
    border-color: ${dark_active_background_color} !important;
  }


  /* ---- Catch-all: .bg-white anywhere inside theme, except canvas ----
     Uses :not(.dac-canvas *) to preserve per-block theming inside canvas. */
  .bg-white:not(.dac-canvas):not(.dac-canvas *) {
    background: ${dark_background_color} !important;
  }


  /* =================================================================
     (B) PORTALED POPOVERS — at top level, NO prefix
     The zoom menu (46%/Zoom in/Zoom out/...), operator dropdown,
     value-select dropdown, timezone picker — all mount here.
     KEY: .hui-popper-content is the visible panel (not -floating-inner).
     ================================================================= */
  .hui-popper-content,
  .hui-popper-floating-inner,
  .v-popper--theme-dropdown .v-popper__inner {
    background: ${dark_background_color} !important;
    color: ${dark_text_color} !important;
    border-color: ${dark_border_color} !important;
    box-shadow: none !important;
  }
  .hui-popper-arrow {
    background: ${dark_background_color} !important;
    border-color: ${dark_border_color} !important;
  }

  /* Inputs inside popovers (zoom %, search boxes) */
  .hui-popper-content input,
  .hui-popper-floating-inner input {
    background: ${dark_background_color} !important;
    color: ${dark_text_color} !important;
    border-color: ${dark_border_color} !important;
  }
  .hui-popper-content input::placeholder,
  .hui-popper-floating-inner input::placeholder {
    color: ${dark_placeholder_color} !important;
  }

  /* Menu items: Zoom in, Zoom out, Fit to width, Etc/UTC options, etc. */
  .hui-popper-content .hui-dropdown-item,
  .hui-popper-content [role="menuitem"],
  .hui-popper-content [role="option"],
  .hui-popper-floating-inner .hui-dropdown-item,
  .hui-popper-floating-inner [role="menuitem"],
  .hui-popper-floating-inner [role="option"] {
    color: ${dark_text_color} !important;
    background: transparent !important;
  }
  .hui-popper-content .hui-dropdown-item:hover,
  .hui-popper-content [role="menuitem"]:hover,
  .hui-popper-content [role="option"]:hover,
  .hui-popper-floating-inner .hui-dropdown-item:hover,
  .hui-popper-floating-inner [role="menuitem"]:hover,
  .hui-popper-floating-inner [role="option"]:hover {
    background: ${dark_active_background_color} !important;
    color: ${dark_text_color} !important;
  }

  /* Fallback: .bg-white inside popovers */
  .hui-popper-content .bg-white,
  .hui-popper-floating-inner .bg-white {
    background: ${dark_background_color} !important;
  }
  ;;
  }
)

Dashboard test_zoom {
  title: 'Insights'
  description: ''

  view: TabLayout {
    label: 'View 1'
    tab tab1: CanvasLayout {
      default_zoom: 'fit_to_width'
      label: 'Overview'
      width: 1700
      height: 2840
      grid_size: 20
      auto_expand_vertically: true

      mobile {
        mode: 'auto'
      }
      block f_airbnb_listings_id {
        position: pos(920, 640, 300, 80)
      }
      block f_airbnb_listings_id_vuz1 {
        position: pos(540, 600, 300, 80)
      }
    }
    tab tab2: CanvasLayout {
      default_zoom: 'fit_to_width'
      label: 'Games'
      width: 1700
      height: 540
      grid_size: 20
      auto_expand_vertically: true
      mobile {
        mode: 'auto'
      }
    }
    tab tab_l4op: CanvasLayout {
      default_zoom: 'fit_to_width'
      label: 'Players'
      width: 1700
      height: 1560
      grid_size: 20
      auto_expand_vertically: true
      mobile {
        mode: 'auto'
      }
    }
  }
  settings {
    timezone: 'Etc/UTC'
    allow_timezone_change: true
    cache_duration: 1440
  }
  theme: squad_dark_pro_max
  block f_airbnb_listings_id: FilterBlock {
    label: 'Airbnb Listings Id'
    type: 'field'
    source: FieldFilterSource {
      dataset: airbnb_data
      field: r(ecommerce_demo_pointmap_airbnb.id)
    }
    default {
      operator: 'is'
      value: '$H_NIL$'
    }
  }
  block f_airbnb_listings_id_vuz1: FilterBlock {
    label: 'Airbnb Listings Id'
    type: 'field'
    source: FieldFilterSource {
      dataset: airbnb_data
      field: r(ecommerce_demo_pointmap_airbnb.id)
    }
    default {
      operator: 'is'
      value: '$H_NIL$'
    }
  }
  interactions: [
    FilterInteraction {
      from: 'f_airbnb_listings_id'
      to: [
        CustomMapping {
          block: 'f_airbnb_listings_id_vuz1'
          disabled: true
        }
      ]
    },
    FilterInteraction {
      from: 'f_airbnb_listings_id_vuz1'
      to: [
        CustomMapping {
          block: 'f_airbnb_listings_id'
          disabled: true
        }
      ]
    }
  ]
}