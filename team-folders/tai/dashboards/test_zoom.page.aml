
const dark_background_color = 'green'
const dark_surface_color = 'green'
const dark_border_color = 'purple'
const dark_text_color = 'white'
const dark_muted_color = 'gray'
const dark_placeholder_color = 'red'
const dark_active_background_color = 'purple'
const dark_active_text_color = 'black'

//  ${dark_background_color}         main panel / canvas bg
//  ${dark_surface_color}             NEW — input/dropdown bg  (slightly lighter than main bg)
//  ${dark_border_color}              NEW — dividers & borders
//  ${dark_text_color}                primary text
//  ${dark_muted_color}               NEW — secondary/empty-state text
//  ${dark_placeholder_color}         input placeholders
//  ${dark_active_background_color}   hover / active states

const squad_dark_pro_max = squad_dark.extend(
  {
    custom_css: @css 
 /* ---- 1. Dashboard title ("Insights") ---------------------- */
  .dac-metadata [data-ci="ci-dashboard-title"],
  .dac-metadata .truncate,
  .dac-metadata * {
    color: ${dark_text_color} !important;
  }
 
 
  /* ---- 2. Controls panel accordion sections ----------------- */
  /* "In this tab" and "From other tabs" are .h-controls-accordion
     with internal [data-hui-section="header"] and [data-hui-section="body"]. */
  .h-controls-accordion,
  .h-controls-accordion [data-hui-section="header"],
  .h-controls-accordion [data-hui-section="body"] {
    background: ${dark_background_color} !important;
    color: ${dark_text_color} !important;
    border-color: ${dark_border_color} !important;
  }
  /* Section title text + chevron icons in the accordion header */
  .h-controls-accordion [data-hui-section="header"] * {
    color: ${dark_text_color} !important;
  }
  .h-controls-accordion svg,
  .h-controls-accordion .h-icon {
    color: ${dark_text_color} !important;
    fill: currentColor !important;
  }
  /* Empty-state text "No filters & controls." */
  .h-controls-accordion .text-gray-500,
  .h-controls-accordion [class*="text-gray-"] {
    color: ${dark_placeholder_color} !important;
  }
 
 
  /* ---- 3. Scrollbars (WebKit/Chromium) ---------------------- */
  *::-webkit-scrollbar {
    width: 10px;
    height: 10px;
  }
  *::-webkit-scrollbar-track {
    background: ${dark_background_color};
  }
  *::-webkit-scrollbar-thumb {
    background: ${dark_border_color};
    border-radius: 5px;
    border: 2px solid ${dark_background_color};
  }
  *::-webkit-scrollbar-thumb:hover {
    background: ${dark_active_background_color};
  }
  /* Firefox */
  * {
    scrollbar-color: ${dark_border_color} ${dark_background_color};
    scrollbar-width: thin;
  }
 
 
  /* ---- 4. Missed popover wrappers (zoom menu, timezone list) -
     Last round I had .hui-popper-content + .hui-popper-floating-inner
     but .hui-dropdown triggers mount to .hui-dropdown-floating, and
     plain .hui-popover uses .hui-popover-floating. Adding both. */
  .hui-dropdown-floating,
  .hui-popover-floating,
  .hui-popover-onboarding-floating {
    background: ${dark_background_color} !important;
    color: ${dark_text_color} !important;
    border-color: ${dark_border_color} !important;
    box-shadow: none !important;
  }
 
  /* Items inside these wrappers */
  .hui-dropdown-floating .hui-dropdown-item,
  .hui-dropdown-floating [role="menuitem"],
  .hui-dropdown-floating [role="option"],
  .hui-popover-floating .hui-dropdown-item,
  .hui-popover-floating [role="menuitem"],
  .hui-popover-floating [role="option"] {
    color: ${dark_text_color} !important;
    background: transparent !important;
  }
  .hui-dropdown-floating .hui-dropdown-item:hover,
  .hui-dropdown-floating [role="menuitem"]:hover,
  .hui-dropdown-floating [role="option"]:hover,
  .hui-popover-floating .hui-dropdown-item:hover,
  .hui-popover-floating [role="menuitem"]:hover,
  .hui-popover-floating [role="option"]:hover {
    background: ${dark_active_background_color} !important;
    color: ${dark_text_color} !important;
  }
 
  /* Zoom % input inside the dropdown */
  .hui-dropdown-floating input {
    background: ${dark_background_color} !important;
    color: ${dark_text_color} !important;
    border-color: ${dark_border_color} !important;
  }
 
  /* .bg-white fallback inside dropdown/popover wrappers */
  .hui-dropdown-floating .bg-white,
  .hui-popover-floating .bg-white {
    background: ${dark_background_color} !important;
  }
  ;;
  }
)

Dashboard test_zoom {
  title: 'Insights'
  description: ''

  view: TabLayout {
    label: 'View 1'
    tab tab1: CanvasLayout {
      default_zoom: 'fit_to_width'
      label: 'Overview'
      width: 1700
      height: 2840
      grid_size: 20
      auto_expand_vertically: true

      mobile {
        mode: 'auto'
      }
      block f_airbnb_listings_id {
        position: pos(920, 640, 300, 80)
      }
      block f_airbnb_listings_id_vuz1 {
        position: pos(540, 600, 300, 80)
      }
    }
    tab tab2: CanvasLayout {
      default_zoom: 'fit_to_width'
      label: 'Games'
      width: 1700
      height: 540
      grid_size: 20
      auto_expand_vertically: true
      mobile {
        mode: 'auto'
      }
    }
    tab tab_l4op: CanvasLayout {
      default_zoom: 'fit_to_width'
      label: 'Players'
      width: 1700
      height: 1560
      grid_size: 20
      auto_expand_vertically: true
      mobile {
        mode: 'auto'
      }
    }
  }
  settings {
    timezone: 'Etc/UTC'
    allow_timezone_change: true
    cache_duration: 1440
  }
  theme: squad_dark_pro_max
  block f_airbnb_listings_id: FilterBlock {
    label: 'Airbnb Listings Id'
    type: 'field'
    source: FieldFilterSource {
      dataset: airbnb_data
      field: r(ecommerce_demo_pointmap_airbnb.id)
    }
    default {
      operator: 'is'
      value: '$H_NIL$'
    }
  }
  block f_airbnb_listings_id_vuz1: FilterBlock {
    label: 'Airbnb Listings Id'
    type: 'field'
    source: FieldFilterSource {
      dataset: airbnb_data
      field: r(ecommerce_demo_pointmap_airbnb.id)
    }
    default {
      operator: 'is'
      value: '$H_NIL$'
    }
  }
  interactions: [
    FilterInteraction {
      from: 'f_airbnb_listings_id'
      to: [
        CustomMapping {
          block: 'f_airbnb_listings_id_vuz1'
          disabled: true
        }
      ]
    },
    FilterInteraction {
      from: 'f_airbnb_listings_id_vuz1'
      to: [
        CustomMapping {
          block: 'f_airbnb_listings_id'
          disabled: true
        }
      ]
    }
  ]
}