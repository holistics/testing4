    --text-lightness: calc(25 + (1 - var(--percentage)) * 30);

    font-weight: 500;
    min-width: 55px;
    background-color: hsl(var(--hue) var(--saturation) calc(var(--bg-lightness) * 1%));
    color: hsl(var(--hue) var(--saturation) calc(var(--text-lightness) * 1%));
