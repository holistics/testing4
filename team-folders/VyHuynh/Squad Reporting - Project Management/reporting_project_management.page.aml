  </span>

  <div class="kpi-bug-ratio-compare" style="margin-top: 8px">
      {{ rows[0].values.`Completed Issue Icon` }}
      {{ rows[0].values.`LM - Number of Bug` }}
  <span style="color: #525866;">
      vs last month</span>
  </div>

