  block v_3qu5: VizBlock {
    label: 'Burnup Created vs Completed'
    viz: AreaChart {
      dataset: reporting_project_management
      calculation metric_93579d9 {
        label: 'Running total of Count of Reporting Burnup Created'
        formula: @aql count(reporting_burnup.created) | running_total();;
        calc_type: 'measure'
        data_type: 'number'
      }
      x_axis: VizFieldFull {
        ref: r(reporting_burnup.week)
        transformation: 'datetrunc week'
        format {
          type: 'date'
          pattern: 'LLL dd, yyyy'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            label: 'Created'
            ref: r(reporting_burnup.created)
            aggregation: 'running sum'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
        series {
          field: VizFieldFull {
            label: 'Completed'
            ref: r(reporting_burnup.completed)
            aggregation: 'running sum'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
      }
      settings {
        row_limit: 5000
        legend_label: 'hidden'
        x_axis_show_null_datetime: false
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
